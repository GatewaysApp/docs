{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Gateways",
  "public": true,
  "description": "Gateways documentation: platform and console guides, product comparisons, and REST API reference.",
  "colors": {
    "primary": "#3b82f6",
    "light": "#60a5fa",
    "dark": "#2563eb"
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/images/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Platform",
            "expanded": true,
            "root": "index",
            "pages": ["gateways/overview", "gateways/create-account"]
          },
          {
            "group": "CLI",
            "expanded": true,
            "root": "gateways/cli/index",
            "pages": [
              {
                "group": "Get started",
                "expanded": true,
                "pages": [
                  "gateways/cli/install",
                  "gateways/cli/initialize-project",
                  "gateways/cli/project-file"
                ]
              },
              "gateways/cli/commands"
            ]
          },
          {
            "group": "Compare",
            "expanded": true,
            "root": "platform/index",
            "pages": [
              "platform/compare-to-vercel",
              "platform/compare-to-netlify",
              "platform/compare-to-render",
              "platform/compare-to-fly-io",
              "platform/compare-to-heroku",
              "platform/compare-to-railway"
            ]
          },
          {
            "group": "Console",
            "expanded": true,
            "root": "gateways/navigation",
            "pages": [
              "gateways/canvas",
              "gateways/activity-and-project-settings",
              "gateways/account",
              "gateways/troubleshooting"
            ]
          },
          {
            "group": "Resource types",
            "expanded": true,
            "root": "gateways/resources/index",
            "pages": [
              "gateways/resources/server",
              "gateways/resources/scalable-server",
              {
                "group": "Runtime",
                "expanded": true,
                "root": "gateways/resources/runtime/index",
                "pages": [
                  "gateways/resources/runtime/families-and-versions",
                  "gateways/resources/runtime/application-servers",
                  "gateways/resources/runtime/canvas-and-connections"
                ]
              },
              {
                "group": "Application",
                "expanded": true,
                "root": "gateways/resources/application/index",
                "pages": [
                  "gateways/resources/application/sources",
                  "gateways/resources/application/upload-and-build",
                  "gateways/resources/application/git-repositories",
                  "gateways/resources/application/docker-image",
                  "gateways/resources/application/canvas-and-operations"
                ]
              },
              "gateways/resources/database",
              "gateways/resources/utilities",
              "gateways/resources/firewall",
              "gateways/resources/dns",
              "gateways/resources/storage-bucket",
              "gateways/resources/static-website",
              "gateways/resources/cache-server",
              "gateways/resources/function",
              "gateways/resources/connections"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "expanded": true,
            "root": "api-reference/introduction",
            "pages": ["api/index"]
          },
          {
            "group": "Authentication & access",
            "expanded": true,
            "root": "api/00-authentication-access",
            "pages": ["api/01-authentication"]
          },
          {
            "group": "Projects & cloud",
            "expanded": true,
            "root": "api/02-projects-environments",
            "pages": ["api/03-cloud-connections"]
          },
          {
            "group": "Resources & applications",
            "expanded": true,
            "root": "api/04-servers-instances",
            "pages": [
              "api/05-resources",
              "api/06-applications",
              "api/07-resource-connections",
              "api/08-firewalls",
              "api/09-storage-buckets",
              "api/10-resource-positions",
              "api/11-utility-resources",
              "api/14-bucket-explorers",
              "api/15-bucket-files",
              "api/16-static-websites"
            ]
          },
          {
            "group": "Infrastructure & catalog",
            "expanded": true,
            "root": "api/12-cloud-infrastructure",
            "pages": ["api/13-legacy"]
          },
          {
            "group": "Data & compute",
            "expanded": true,
            "root": "api/18-databases",
            "pages": ["api/19-cache-servers", "api/21-functions"]
          },
          {
            "group": "Activity, plans & workspaces",
            "expanded": true,
            "root": "api/22-activities",
            "pages": ["api/23-pricing-plans", "api/24-workspaces", "api/25-payments"]
          },
          {
            "group": "DNS & scaling",
            "expanded": true,
            "root": "api/25-dns",
            "pages": ["api/26-subdomains", "api/27-scalable-servers", "api/28-runtimes"]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://gateways.app"
  },
  "navbar": {
    "links": [
      {
        "label": "Gateways Home",
        "href": "https://gateways.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Console",
      "href": "https://console.gateways.app/login"
    }
  },
  "footer": {
    "links": [
      {
        "header": "Gateways",
        "items": [
          {
            "label": "Home",
            "href": "https://gateways.app"
          },
          {
            "label": "Console",
            "href": "https://console.gateways.app"
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
